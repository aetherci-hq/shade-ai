{
  "name": "shade-ai",
  "version": "0.2.0",
  "description": "Shade — Lightweight Autonomous AI Agent. Persistent memory, heartbeat daemon, voice output, custom tools, and a dashboard.",
  "type": "module",
  "bin": {
    "shade-ai": "dist/index.js",
    "shade": "dist/index.js"
  },
  "scripts": {
    "build": "tsup && cp -r ../dashboard/dist dist/dashboard 2>/dev/null || xcopy /E /I /Q ..\\dashboard\\dist dist\\dashboard >nul 2>&1 || true",
    "build:tsc": "tsc",
    "dev": "tsx src/index.ts"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai", "agent", "autonomous", "claude", "shade",
    "personal-assistant", "ai-agent", "chatbot", "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aetherci-hq/shade-ai"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.80",
    "@xenova/transformers": "^2.17.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "glob": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@shade/core": "*",
    "@shade/server": "*",
    "@types/node": "^18.19.130",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0"
  }
}
